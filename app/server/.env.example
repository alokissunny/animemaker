PORT=8787

# ChatGPT / OpenAI — powers character bios, story generation, scene breakdown, captions
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# Google Gemini API key — powers both Nano Banana (image generation) and Veo (video generation).
# Only needed if GOOGLE_GENAI_USE_VERTEXAI is not "true" below.
GOOGLE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VEO_MODEL=veo-3.1-generate-preview

# --- OR: use Vertex AI instead of the Gemini Developer API key above ---
# Needed if you're on Google Cloud credits: the Developer API key has its own separate
# (often much lower) quota that credits don't apply to. Vertex AI bills to the GCP
# project below, so Cloud credits work normally. See README "Using Vertex AI" section.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Auth: either set GOOGLE_APPLICATION_CREDENTIALS to a service account key file path
# (standard ADC, works with `gcloud auth application-default login` too), or paste the
# key's JSON directly here (handy when you can't mount a file, e.g. some PaaS hosts):
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Fixed test credential for the login screen (no real accounts in this MVP)
TEST_LOGIN_EMAIL=demo@nova.app
TEST_LOGIN_PASSWORD=showtime123

# Where saved projects + generated video files are persisted to disk. Defaults to
# ./data next to the server process. On most hosts this must be a persistent volume
# to survive restarts/redeploys — see the README's Deploying section.
DATA_DIR=./data

PORT=8787

# ChatGPT / OpenAI — powers character bios, story generation, scene breakdown, captions
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini

# Google Gemini API key — powers both Nano Banana (image generation) and Veo (video generation)
GOOGLE_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
VEO_MODEL=veo-3.1-generate-preview

# Fixed test credential for the login screen (no real accounts in this MVP)
TEST_LOGIN_EMAIL=demo@nova.app
TEST_LOGIN_PASSWORD=anime123

# Where saved projects + generated video files are persisted to disk. Defaults to
# ./data next to the server process. On most hosts this must be a persistent volume
# to survive restarts/redeploys — see the README's Deploying section.
DATA_DIR=./data
